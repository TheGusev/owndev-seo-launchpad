    {
      "id": "conversion_system",
      "title": "Система конверсии",
      "activation": { "layer": "conversion_system" },
      "order": 11,
      "fields": ["conversion_points", "cta_strategy", "form_requirements"]
    },
    {
      "id": "restructuring",
      "title": "План реструктуризации",
      "activation": { "blocks": ["restructuring_plan"] },
      "order": 12,
      "fields": ["current_state_assessment", "migration_steps", "redirect_plan", "risk_mitigation"]
    },
    {
      "id": "migration_checklist",
      "title": "Чек-лист миграции",
      "activation": { "blocks": ["migration_checklist"] },
      "order": 13,
      "fields": ["pre_migration", "during_migration", "post_migration"]
    },
    {
      "id": "analytics_integration",
      "title": "Аналитика и рекламные интеграции",
      "activation": { "layer": "analytics_ads_integration" },
      "order": 14,
      "fields": ["analytics_setup", "conversion_tracking", "ad_integration"]
    },
    {
      "id": "safe_scale",
      "title": "Безопасное масштабирование",
      "activation": { "checks": ["thin_content_risk", "cannibalization_risk", "doorway_risk"] },
      "order": 15,
      "fields": ["thin_content_assessment", "cannibalization_prevention", "doorway_prevention", "verification_protocol"]
    },
    {
      "id": "technical_stability",
      "title": "Техническая стабильность",
      "always_active": true,
      "order": 16,
      "fields": ["rendering_strategy", "performance_requirements", "security_basics"]
    },
    {
      "id": "next_steps",
      "title": "Следующие шаги",
      "always_active": true,
      "order": 17,
      "fields": ["implementation_priority", "timeline_estimate", "verification_checkpoints"]
    }
  ]
