{
  "name": "owndev-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/config dist/db/migrations && cp -r config dist/config && cp -r src/db/migrations dist/db/migrations && mkdir -p dist/services/demand/profiles && cp src/services/demand/profiles/*.json dist/services/demand/profiles/ && mkdir -p dist/services/verticals/profiles && cp src/services/verticals/profiles/*.json dist/services/verticals/profiles/",
    "start": "node dist/index.js",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "test:v1-untouched": "tsx src/services/SiteFormula/__tests__/v1-untouched.ts",
    "test:pr2-rules-weights": "tsx src/services/preflight/__tests__/pr2-rules-weights.ts",
    "test:pr3-page-fanout": "tsx src/services/strategy/__tests__/pr3-page-fanout.ts",
    "test:pr4-self-test-matrix": "tsx src/services/strategy/__tests__/pr4-self-test-matrix.ts",
    "test:pr5-vertical-profiles": "tsx src/services/verticals/__tests__/pr5-vertical-profiles.ts",
    "test:pr6-pro-report": "tsx src/services/pipeline/__tests__/pr6-pro-report.ts",
    "test:pr7-ad-market": "tsx src/services/pipeline/__tests__/pr7-ad-market.ts",
    "test:pr8-vertical-audit": "tsx src/services/pipeline/__tests__/pr8-vertical-audit.ts",
    "test:pr11-cross-product": "tsx src/services/strategy/__tests__/pr11-cross-product-fanout.ts",
    "test:bridge": "npm run test:v1-untouched && npm run test:pr2-rules-weights && npm run test:pr3-page-fanout && npm run test:pr4-self-test-matrix && npm run test:pr5-vertical-profiles && npm run test:pr6-pro-report && npm run test:pr7-ad-market && npm run test:pr8-vertical-audit && npm run test:pr11-cross-product",
    "migrate:geo-rating": "tsx scripts/migrate-geo-rating-from-supabase.ts",
    "rescan:geo": "tsx scripts/rescan-geo-rating.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bullmq": "^5.25.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.0",
    "jszip": "^3.10.1",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
